CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# Discord Activity OAuth (backend token exchange — keep secret)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Comma-separated origins allowed for Socket.IO
SOCKET_CORS_ORIGINS=https://local.sweeptogether.com,http://local.sweeptogether.com,http://localhost:8080

# Public URL served by Cloudflare tunnel (Discord URL mapping target)
PUBLIC_URL=https://local.sweeptogether.com

# Docker Compose resource caps (defaults ≈ half of an 8-core machine for backend+frontend)
# Also set Docker Desktop → Settings → Resources → CPUs to at least this total.
DOCKER_BACKEND_CPU_LIMIT=4.0
DOCKER_FRONTEND_CPU_LIMIT=2.0
DOCKER_MONGO_CPU_LIMIT=2.0
DOCKER_NGINX_CPU_LIMIT=1.0
DOCKER_CLOUDFLARED_CPU_LIMIT=0.5
DOCKER_MONGO_EXPRESS_CPU_LIMIT=0.5
