# Frontend telemetry (Vite — rebuild required)
# Enabled by default in dev; set true in production builds to collect data.
VITE_TELEMETRY_ENABLED=true

# Force A/B cohort: control (legacy buffer/debounce) | treatment (optimized) | omit for random sticky assignment
# VITE_AB_VARIANT=treatment

# Override in browser: ?ab=control or ?ab=treatment
VITE_AB_VARIANT=treatment 